					"_Name": "draw_set_swf_aa_level",
					"_Deprecated": "false",
					"_ReturnType": "Undefined",
					"_Pure": "false"
				},
				{
					"Description": "With this function you can enable or disable anti-aliasing (AA) for SVG format vector sprites. AA simply smooths the edges of vector images to give them a nicer look. The amount of AA used will depend on the value set using the function draw_set_svg_aa_level(). By default this is disabled.",
					"Parameter": {
						"_Name": "enable",
						"_Type": "Bool",
						"_Optional": "false",
						"__text": "Enable (true) or disable (false) AA for all SVG sprites."
					},
					"_Name": "draw_enable_svg_aa",
					"_Deprecated": "false",
					"_ReturnType": "Undefined",
					"_Pure": "false"
				},
				{
					"Description": "This function can be used to get the anti-aliasing (AA) level for SVG format vector sprites. The return value will between 0 and 1 and shows how \"smooth\" the edges of these sprites will be drawn. You can set the AA level using the function draw_set_svg_aa_level().",
					"_Name": "draw_get_svg_aa_level",
					"_Deprecated": "false",
					"_ReturnType": "Real",
					"_Pure": "true"
				},
				{
					"Description": "This function can be used to set the anti-aliasing (AA) level for SVG format vector sprites. This can be a real value from 0 to 1 and will \"smooth\" the edges of these sprites. Note that to see this effect, you must first have enabled AA using the function draw_enable_svg_aa().",
					"Parameter": {
						"_Name": "aa",
