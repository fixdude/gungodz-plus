					"Description": "This function flushes the entire draw pipeline.",
					"_Name": "draw_flush",
					"_Deprecated": "false",
					"_ReturnType": "Undefined",
					"_Pure": "false"
				},
				{
					"Description": "This function will draw an arrow from point (x1, y1) to point (x2, y2). The stem of the arrow is drawn along these points with the actual arrow head being drawn at the end, where the size of the arrowhead is defined by the argument \"size\" and is calculated as being part of the stem so that the end point is always aligned with the position defined by (x2, y2). The width of the arrow head is calculated automatically in proportion to the length.",
					"Parameter": [
						{
							"_Name": "x1",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The x coordinate of the start of the line."
						},
						{
							"_Name": "y1",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The y coordinate of the start of the line."
						},
						{
							"_Name": "x2",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The x coordinate of the end of the line (where the arrowhead ends)."
						},
						{
							"_Name": "y2",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The y coordinate of the end of the line (where the arrowhead ends)."
						},
						{
							"_Name": "size",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The length of the arrow in pixels."
						}
					],
					"_Name": "draw_arrow",
					"_Deprecated": "false",
					"_ReturnType": "Undefined",
					"_Pure": "false"
				},
				{
					"Description": "This function will draw a very simple, rectangular \"button\" using the currently selected draw colour and alpha where the up argument defines how the beveled edge effect looks.",
