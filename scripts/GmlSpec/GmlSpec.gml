							"_Set": "true"
						}
					],
					"_Name": "AnimCurveChannel"
				},
				{
					"Field": [
						{
							"_Name": "posx",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The x position of the point"
						},
						{
							"_Name": "value",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The value at the x position"
						}
					],
					"_Name": "AnimCurvePoint"
				},
				{
					"Field": [
						{
							"_Name": "activeTracks",
							"_Type": "Array[Struct.Track]",
							"_Get": "true",
							"_Set": "false",
							"__text": "READ-ONLY This is an array of evaluation structs for each parameter track that the asset track contains. The contents of each struct in the array are listed on the manual's Track Struct page."
						},
						{
							"_Name": "matrix",
							"_Type": "Array",
							"_Get": "true",
							"_Set": "true",
							"__text": "The transformation matrix of the track within the parent track's frame of reference (all asset track types)."
						},
						{
							"_Name": "posx",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The position of the asset in the sequence along the X axis for the track (all asset track types)."
						},
						{
							"_Name": "posy",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The position of the asset in the sequence along the Y axis for the track (all asset track types)."
						},
						{
							"_Name": "scalex",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The scale of the asset in the sequence along the X axis for the track (group, particle system, instance, sequence, text and sprite asset track types)."
						},
						{
							"_Name": "scaley",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The scale of the asset in the sequence along the Y axis for the track (group, particle system, instance, sequence, text and sprite asset track types)."
						},
						{
							"_Name": "xorigin",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The X origin of the asset for the track (group, particle system, instance, sequence, text and sprite asset track types)."
						},
						{
							"_Name": "yorigin",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The Y origin of the asset for the track (group, particle system, instance, sequence, text and sprite asset track types)."
						},
						{
							"_Name": "gain",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The gain of the track, which is the emitter gain."
						},
						{
							"_Name": "pitch",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The pitch of the track, which is the emitter pitch."
						},
						{
							"_Name": "falloffRef",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The audio emitter's falloff reference distance."
						},
						{
							"_Name": "falloffMax",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The audio emitter's falloff maximum distance."
						},
						{
							"_Name": "falloffFactor",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The audio emitter's falloff factor."
