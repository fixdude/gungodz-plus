					"_Pure": "false"
				},
				{
					"Description": "With this function you can draw either an outline of a rounded rectangle or a filled rounded rectangle where the (x1, y1) position is the top left corner and the (x2, y2) position is the bottom right corner. If the rectangle is filled, then the colour arguments will be used to generate a colour gradient from the centre to the edges, where colour 1 is the centre colour and colour 2 the edge colour. You must also supply radius values for the x and y axis (in pixels) and the corners will be rounded by these amounts. You can define how precise the drawing of the corners is with the function draw_set_circle_precision(). Please note that the rectangle being drawn may need different values (+/-1 on the x, y, or width or height) to be drawn with the desired dimensions due to differences across the various supported platforms.",
					"Parameter": [
						{
							"_Name": "x1",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The x coordinate of the left of the rounded rectangle."
						},
						{
							"_Name": "y1",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The y coordinate of the top of the rounded rectangle."
						},
						{
							"_Name": "x2",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The x coordinate of the right of the rounded rectangle."
						},
						{
							"_Name": "y2",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The y coordinate of the bottom of the rounded rectangle."
						},
						{
							"_Name": "xrad",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The radius of the curve along the x axis from the rectangle corners."
						},
						{
							"_Name": "yrad",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The radius of the curve along the y axis from the rectangle corners."
						},
						{
							"_Name": "col1",
							"_Type": "Constant.Color",
							"_Optional": "false",
							"__text": "The center colour."
						},
						{
							"_Name": "col2",
							"_Type": "Constant.Color",
							"_Optional": "false",
							"__text": "The outside edge colour."
						},
						{
							"_Name": "outline",
							"_Type": "Bool",
							"_Optional": "false",
							"__text": "Whether the rectangle is an outline (true) or filled in (false)."
						}
					],
