							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The horizontal size of the text frame."
						},
						{
							"_Name": "frameSizeY",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The vertical size of the text frame."
						},
						{
							"_Name": "characterSpacing",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The character spacing value."
						},
						{
							"_Name": "lineSpacing",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The line spacing value."
						},
						{
							"_Name": "paragraphSpacing",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The paragraph spacing value."
						},
						{
							"_Name": "thickness",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The thickness of the SDF effect."
						},
						{
							"_Name": "coreColor",
							"_Type": "Array",
							"_Get": "true",
							"_Set": "true",
							"_Locale": "US",
							"__text": "An array of 4 values, each from 0 to 1, corresponding to ARGB values of the 'core' part of the glyph."
						},
						{
							"_Name": "coreColour",
							"_Type": "Array",
							"_Get": "true",
							"_Set": "true",
							"_Locale": "GB",
							"__text": "An array of 4 values, each from 0 to 1, corresponding to ARGB values of the 'core' part of the glyph."
