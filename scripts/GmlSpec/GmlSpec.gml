					"_Deprecated": "false",
					"_ReturnType": "Undefined",
					"_Locale": "US",
					"_Pure": "false"
				},
				{
					"Description": "With this function you can set the mix of red, green and blue colors for all particles created of the given type. All values must be between 0 and 255.",
					"Parameter": [
						{
							"_Name": "ind",
