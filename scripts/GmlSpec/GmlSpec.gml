						"_Optional": "false",
						"__text": "The anti-aliasing value to use from 0 to 1."
					},
					"_Name": "draw_set_svg_aa_level",
					"_Deprecated": "false",
					"_ReturnType": "Undefined",
					"_Pure": "false"
				},
				{
					"Description": "This function can be used to set the maximum size of the cache used to accelerate the drawing of SWF and SVG format vector sprites. This can be a value of 0 or greater. A value of 0 will disable the cache. Changing this value will reset the return value of vector_sprite_get_cache_max_used().",
					"Parameter": {
						"_Name": "limit",
						"_Type": "Real",
						"_Optional": "false",
						"__text": "The cache size in bytes."
					},
					"_Name": "vector_sprite_cache_limit",
					"_Deprecated": "false",
					"_ReturnType": "Undefined",
					"_Pure": "false"
				},
				{
					"Description": "This function sets what fraction of the SWF and SVG vector sprite cache is attempted to be cleared each frame. This can be a value between 0.0 and 1.0 (a value of 0.0 will disabled automatic pruning). This will only attempt to clear cache entries that are older than the number of frames specified by vector_sprite_cache_prune_age().",
					"Parameter": {
						"_Name": "fraction",
						"_Type": "Real",
						"_Optional": "false",
						"__text": "The fraction of the cache size to clear (a value between 0.0 and 1.0)."
					},
					"_Name": "vector_sprite_cache_prune_fraction",
					"_Deprecated": "false",
					"_ReturnType": "Undefined",
					"_Pure": "false"
				},
				{
					"Description": "This function sets how long entries in the SWF and SVG vector sprite cache must not have been used for before being deleted by the automatic pruning logic. This value is measured in frames and should be 0 or greater.",
					"Parameter": {
						"_Name": "frames",
						"_Type": "Real",
						"_Optional": "false",
						"__text": "The number of frames a cache entry can be unused for before being considered for deletion."
					},
					"_Name": "vector_sprite_cache_prune_age",
					"_Deprecated": "false",
					"_ReturnType": "Undefined",
					"_Pure": "false"
				},
				{
					"Description": "This function returns the current maximum size of the SWF and SVG vector sprite cache.",
					"_Name": "vector_sprite_cache_get_limit",
					"_Deprecated": "false",
					"_ReturnType": "Real",
					"_Pure": "true"
				},
				{
					"Description": "This function returns the fraction of the SWF and SVG vector sprite cache that is attempted to be cleared each frame.",
					"_Name": "vector_sprite_cache_get_prune_fraction",
					"_Deprecated": "false",
					"_ReturnType": "Real",
					"_Pure": "true"
				},
				{
					"Description": "This function returns the number of frames an entry in the SWF and SVG vector sprite cache can exist without being used before it is considered for deletion.",
					"_Name": "vector_sprite_cache_get_prune_age",
					"_Deprecated": "false",
					"_ReturnType": "Real",
					"_Pure": "true"
				},
				{
					"Description": "This function returns the current amount of memory used by the SWF and SVG vector sprite cache.",
