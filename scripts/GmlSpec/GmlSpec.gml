				},
				{
					"Description": "This function allows you to attach a surface to a canvas element that already exists in your web page, meaning that you can effectively split up portions of your game to be drawn at various different places within the page.",
					"Parameter": [
						{
							"_Name": "name",
							"_Type": "String",
							"_Optional": "false",
							"__text": "The name of the canvas element to link the surface to."
						},
						{
							"_Name": "w",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The width of the surface to be created."
