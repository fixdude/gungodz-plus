							"__text": "The single color to make the particle type."
						}
					],
					"_Name": "part_type_color1",
					"_Deprecated": "false",
					"_ReturnType": "Undefined",
					"_Locale": "US",
					"_Pure": "false"
				},
				{
					"Description": "This function can be used to set a two color gradient for each particle created of the given type. The first color is that which all particles will start with, and the second color is the one on which the particle will end with, and a smooth gradient change will occur to the color over the particle's lifetime from one color to the other.",
					"Parameter": [
						{
							"_Name": "ind",
							"_Type": "Id.ParticleType",
							"_Optional": "false",
							"__text": "The index of the particle type to change."
						},
						{
							"_Name": "colour1",
							"_Type": "Constant.Color",
							"_Optional": "false",
							"__text": "The color the particle will start at."
						},
						{
							"_Name": "colour2",
							"_Type": "Constant.Color",
							"_Optional": "false",
							"__text": "The color the particle will end at."
						}
					],
					"_Name": "part_type_color2",
					"_Deprecated": "false",
					"_ReturnType": "Undefined",
					"_Locale": "US",
					"_Pure": "false"
				},
				{
					"Description": "This function can be used to set a three color gradient for each particle created of the given type. The first color is that which all particles will start with, and the second color is the one that will be blended to half way through its lifetime and the third color is the one with which the particle will end with. A smooth gradient change will occur through the colors over the particle's lifetime from one color to the other.",
					"Parameter": [
						{
							"_Name": "ind",
							"_Type": "Id.ParticleType",
							"_Optional": "false",
							"__text": "The index of the particle type to change."
						},
						{
							"_Name": "colour1",
							"_Type": "Constant.Color",
							"_Optional": "false",
							"__text": "The color the particle will start at."
						},
						{
							"_Name": "colour2",
							"_Type": "Constant.Color",
							"_Optional": "false",
							"__text": "The color the particle will be halfway through its lifespan."
						},
						{
							"_Name": "colour3",
							"_Type": "Constant.Color",
							"_Optional": "false",
							"__text": "The color the particle will end at."
						}
					],
					"_Name": "part_type_color3",
					"_Deprecated": "false",
					"_ReturnType": "Undefined",
					"_Locale": "US",
					"_Pure": "false"
				},
				{
					"Description": "With this function you can set the given particle type to be a random blend of two colors.",
