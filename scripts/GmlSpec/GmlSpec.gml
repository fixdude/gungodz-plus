				{
					"_Name": "audio_falloff_exponent_distance",
					"_Class": "AudioFalloff",
					"_Type": "Real",
					"_Deprecated": "false",
					"__text": "gain = (listener_distance / reference_distance) ^ (-falloff_factor)"
				},
				{
					"_Name": "audio_falloff_exponent_distance_clamped",
					"_Class": "AudioFalloff",
					"_Type": "Real",
					"_Deprecated": "false",
					"__text": "distance = clamp(listener_distance, reference_distance, maximum_distance) gain = (distance / reference_distance) ^ (-falloff_factor)"
				},
				{
					"_Name": "audio_falloff_exponent_distance_scaled",
					"_Class": "AudioFalloff",
					"_Type": "Real",
					"_Deprecated": "false",
					"__text": "distance = clamp(listener_distance, reference_distance, maximum_distance) gain = ((distance / reference_distance) ^ (-falloff_factor)) * (((maximum_distance - distance) / (maximum_distance - reference_distance)) ^ (distance / maximum_distance))"
				},
				{
					"_Name": "audio_falloff_inverse_distance",
					"_Class": "AudioFalloff",
					"_Type": "Real",
					"_Deprecated": "false",
					"__text": "gain = reference_distance / (reference_distance + falloff_factor * (listener_distance - reference_distance))"
				},
				{
					"_Name": "audio_falloff_inverse_distance_clamped",
					"_Class": "AudioFalloff",
					"_Type": "Real",
					"_Deprecated": "false",
					"__text": "distance = clamp(listener_distance, reference_distance, maximum_distance) gain = reference_distance / (reference_distance + falloff_factor * (distance - reference_distance))"
				},
				{
					"_Name": "audio_falloff_inverse_distance_scaled",
					"_Class": "AudioFalloff",
					"_Type": "Real",
					"_Deprecated": "false",
					"__text": "distance = clamp(listener_distance, reference_distance, maximum_distance) gain = (reference_distance / (reference_distance + falloff_factor * (distance - reference_distance))) * (((maximum_distance - distance) / (maximum_distance - reference_distance)) ^ (distance / maximum_distance))"
				},
				{
					"_Name": "audio_falloff_linear_distance",
					"_Class": "AudioFalloff",
					"_Type": "Real",
					"_Deprecated": "false",
					"__text": "distance = min(distance, maximum_distance) gain = (1 - falloff_factor * (distance - reference_distance) / (maximum_distance - reference_distance))"
				},
				{
					"_Name": "audio_falloff_linear_distance_clamped",
					"_Class": "AudioFalloff",
					"_Type": "Real",
					"_Deprecated": "false",
					"__text": "distance = clamp(listener_distance, reference_distance, maximum_distance) gain = (1 - falloff_factor * (distance - reference_distance) / (maximum_distance - reference_distance))"
				},
				{
					"_Name": "audio_falloff_none",
					"_Class": "AudioFalloff",
					"_Type": "Real",
					"_Deprecated": "false",
					"__text": "gain = 1"
				},
