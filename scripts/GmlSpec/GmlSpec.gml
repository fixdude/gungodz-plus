					"_Type": "Real",
					"_Deprecated": "false",
					"__text": "This constant indicates that image decompression failed (which could be due to e.g. a corrupted file or unsupported image format)."
				},
				{
					"_Name": "sprite_add_ext_error_setupfailed",
					"_Type": "Real",
					"_Deprecated": "false",
					"__text": "Indicates that, even though all data was loaded and decompressed, sprite resource creation itself failed."
				}
			]
		},
		"Structures": {
			"Structure": [
				{
					"Field": [
						{
							"_Name": "name",
							"_Type": "String",
							"_Get": "true",
							"_Set": "true",
							"__text": "This is the name of the sequence as a string and you can get or set this value as required. Note that sequences created using the function sequence_create() will not have a name and this will simply be an empty string \"\"."
						},
						{
							"_Name": "loopmode",
							"_Type": "Constant.SeqPlay",
							"_Get": "true",
							"_Set": "true",
							"__text": "This is the playback mode of the sequence object and can be get or set."
						},
						{
							"_Name": "playbackSpeed",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "This specifies the playback speed of the sequence, which is interpreted as either frames-per-second or frames-per-game-frame depending on the playbackSpeedType. You can get or set this value."
						},
						{
							"_Name": "playbackSpeedType",
							"_Type": "Constant.SpriteSpeed",
							"_Get": "true",
							"_Set": "true",
							"__text": "This specifies how the playbackSpeed should be interpreted and you can get or set this value."
						},
						{
							"_Name": "length",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The length of the sequence in frames. You can get or set this value, but note that making a sequence shorter may cause issues if a sequence instance referencing this sequence has its playhead set to past the new length."
						},
						{
							"_Name": "volume",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "This is a scalar value from 0 to 1 that is used to scale the volume of all audio tracks in the sequence. You can get or set this value and it will modify the global audio output for all tracks - for example, if you have an audio track with a volume of 0.8 and then set the sequence volume property to 0.5, the audio track will have a final volume of 0.4."
						},
						{
							"_Name": "xorigin",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "This is the origin of the sequence along the X axis."
						},
						{
							"_Name": "yorigin",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "This is the origin of the sequence along the Y axis."
						},
						{
							"_Name": "messageEventKeyframes",
							"_Type": "Array",
							"_Get": "true",
							"_Set": "true",
							"__text": "This allows access to the message event keyframes for the sequence. You can get or set these message events, and when getting this property an array of keyframe structs is returned, and for setting the property you should supply an array of keyframe structs. For more information, please see the page on Sequence Events and Moments."
						},
						{
							"_Name": "momentKeyframes",
							"_Type": "Array",
							"_Get": "true",
							"_Set": "true",
							"__text": "This allows access to the moment event keyframes for the sequence. You can get or set these moment events, and when getting this property an array of keyframe structs is returned, and for setting the property you should supply an array of keyframe structs. For more information, please see the page on Sequence Events and Moments."
						},
						{
							"_Name": "tracks",
							"_Type": "Array",
							"_Get": "true",
							"_Set": "true",
							"__text": "This allows access to the list of asset tracks on the top level of the sequence. You can get or set this property, and when getting this property an array of track structs is returned, and for setting the property you should supply an array of track structs. For more information, please see the section on Track Structs."
						}
					],
					"_Name": "Sequence"
				},
				{
					"Field": [
						{
							"_Name": "sequence",
							"_Type": "Struct.Sequence",
							"_Get": "true",
							"_Set": "true",
							"__text": "This is the ID of the sequence object struct that the sequence instance has been created from."
						},
						{
							"_Name": "headPosition",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "This is the current playhead position (in frames) for the sequence instance."
						},
						{
							"_Name": "headDirection",
							"_Type": "Constant.SequenceDirection",
							"_Get": "true",
							"_Set": "true",
							"__text": "This is the current playback direction for the sequence instance."
						},
						{
							"_Name": "speedScale",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "This property can be used to get or set the playback speed scale."
						},
						{
							"_Name": "volume",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "This is a scalar value from 0 to 1 that is used to scale the volume of all audio tracks in the sequence. You can get or set this value and it will modify the global audio output for all tracks - for example, if you have an audio track with a volume of 0.8 and then set the sequence volume property to 0.5, the audio track will have a final volume of 0.4."
						},
						{
							"_Name": "paused",
							"_Type": "Bool",
							"_Get": "true",
							"_Set": "true",
							"__text": "You can check this read-only property to see if a sequence has been paused or not, and it will be true if it has, or false otherwise."
						},
						{
							"_Name": "finished",
							"_Type": "Bool",
							"_Get": "true",
							"_Set": "true",
							"__text": "You can check this read-only property to see if a sequence has finished playing or not, returning true if it is finished playing, and false otherwise."
						},
						{
							"_Name": "activeTracks",
							"_Type": "Array[Struct.ActiveTrack]",
							"_Get": "true",
							"_Set": "true",
							"__text": "This read-only property will hold an array of \"evaluation\" structs containing information on the current state of each asset track in the sequence (graphics, sequence, audio, etc.)."
						},
						{
							"_Name": "elementID",
							"_Type": "Id.SequenceElement",
							"_Get": "true",
							"_Set": "true",
							"__text": "This property holds the ID of the sequence element."
						}
					],
					"_Name": "SequenceInstance"
				},
				{
					"Field": [
						{
							"_Name": "name",
							"_Type": "String",
							"_Get": "true",
							"_Set": "true",
							"__text": "When creating a \"top-level\" asset track, the name you give here can be any string that you require to identify the track. However, for parameter tracks, you need to specify specific strings to tell GameMaker what kind of parameter track you are creating."
						},
						{
							"_Name": "type",
							"_Type": "Constant.SequenceTrackType",
							"_Get": "true",
							"_Set": "true",
							"__text": "This contains a Sequence Track Type Constant that describes the type of track."
						},
						{
							"_Name": "tracks",
							"_Type": "Array[Struct.Track]",
							"_Get": "true",
							"_Set": "true",
							"__text": "The list of tracks which are children of this track. When getting this property an array of Sequence Track Structs is returned, and when setting this property an array of Sequence Track Structs should be specified."
						},
						{
							"_Name": "visible",
							"_Type": "Bool",
							"_Get": "true",
							"_Set": "true",
							"__text": "This indicates whether this track is visible (the value is true) or not (the value is false). You can get or set this value and if a track not visible then none of its child tracks will be drawn either."
						},
						{
							"_Name": "keyframes",
							"_Type": "Array[Struct.Keyframe]",
							"_Get": "true",
							"_Set": "true",
							"__text": "This property allows access to the list of keyframe structs for the track. When getting this property an array of keyframe structs is returned, and when setting this property an array of keyframe structs should be specified."
						}
					],
					"_Name": "Track"
				},
				{
					"Field": [
						{
							"_Name": "frame",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The position (in frames) along the timeline for the keyframe. Default value is 0."
						},
						{
							"_Name": "length",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true",
							"__text": "The length of the keyframe. Default value is 1, and when set to larger values then the track property that the keyframe refers to will be maintained at the initial value for the duration of the length given. Note that the stretch property will override this if set to true."
						},
						{
							"_Name": "stretch",
							"_Type": "Bool",
							"_Get": "true",
							"_Set": "true",
							"__text": "If this property is set to true then the keyframe stretches to either the next keyframe for the track or to the end of the track if it's the last keyframe. You can get or set this value, and the default value is false."
						},
						{
							"_Name": "disabled",
							"_Type": "Bool",
							"_Get": "true",
							"_Set": "true",
							"__text": "Whether this keyframe is disabled"
						},
						{
							"_Name": "channels",
							"_Type": "Array",
							"_Get": "true",
							"_Set": "true",
							"__text": "This property allows access to the list of keyframe data structs for the channels of the track. When getting this property an array of keyframe data structs is returned, and when setting this property an array of keyframe data structs should be specified."
						}
					],
					"_Name": "Keyframe"
				},
				{
					"Field": {
						"_Name": "channel",
						"_Type": "Real",
						"_Get": "true",
						"_Set": "true",
						"__text": "The key's channel"
					},
					"_Name": "KeyChannel"
				},
				{
					"Field": {
						"_Name": "spriteIndex",
						"_Type": "Asset.GMSprite",
						"_Get": "true",
						"_Set": "true",
						"__text": "The sprite asset used by the graphic track"
					},
					"_Name": "GraphicTrack"
				},
				{
					"Field": {
						"_Name": "sequence",
						"_Type": "Undefined",
						"_Get": "true",
						"_Set": "true",
						"__text": "The sequence used by the sequence track"
					},
					"_Name": "SequenceTrack"
				},
				{
					"Field": [
						{
							"_Name": "soundIndex",
							"_Type": "Asset.GMSound",
							"_Get": "true",
							"_Set": "true",
							"__text": "READ-ONLY The ID of the sound instance that's playing on this track's emitter."
						},
						{
							"_Name": "emitterIndex",
							"_Type": "Id.EmitterIndex",
							"_Get": "true",
							"_Set": "true",
							"__text": "READ-ONLY The index of the audio emitter used by this track."
						},
						{
							"_Name": "playbackMode",
							"_Type": "Real",
							"_Get": "true",
							"_Set": "true"
						}
					],
					"_Name": "AudioTrack"
				},
				{
					"Field": {
