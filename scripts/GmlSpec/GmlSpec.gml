						"_Type": "Real",
						"_Get": "true",
						"_Set": "true",
						"__text": "The image index"
					},
					"_Name": "SpriteTrack"
				},
				{
					"Field": {
						"_Name": "value",
						"_Type": "Bool",
						"_Get": "true",
						"_Set": "true",
						"__text": "The value of the boolean"
