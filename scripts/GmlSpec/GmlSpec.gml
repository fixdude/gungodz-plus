							"_Optional": "false",
							"__text": "The y coordinate of the top left corner of the area of the screen to capture"
						},
						{
							"_Name": "w",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The width of the area of the screen to capture"
						},
						{
							"_Name": "h",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The height of the area of the screen to capture"
						}
					],
					"_Name": "screen_save_part",
					"_Deprecated": "false",
					"_ReturnType": "Undefined",
					"_Pure": "false"
