							"_Name": "col1",
							"_Type": "Constant.Color",
							"_Optional": "false",
							"__text": "The first color to merge"
						},
						{
							"_Name": "col2",
							"_Type": "Constant.Color",
							"_Optional": "false",
							"__text": "The second color to merge"
						},
						{
							"_Name": "amount",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "How much of each color should be merged. For example, 0 will return col1, 1 will return col2, and 0.5 would return a merge of both colors equally."
						}
					],
					"_Name": "merge_color",
					"_Deprecated": "false",
					"_ReturnType": "Constant.Color",
					"_Locale": "US",
					"_Pure": "true"
