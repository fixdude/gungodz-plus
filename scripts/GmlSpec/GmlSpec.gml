				},
				{
					"Description": "This function returns an array with the UV coordinates and other data for the texture of the sprite sub-image on the texture page. The function returns an array with the following 8 elements:\n\t\t\t\n\t\t\t[0] = left\n\t\t\t\n\t\t\t[1] = top\n\t\t\t\n\t\t\t[2] = right\n\t\t\t\n\t\t\t[3] = bottom\n\t\t\t\n\t\t\t[4] = amount of pixels the asset compiler has trimmed from the sprite's left side\n\t\t\t\n\t\t\t[5] = amount of pixels the asset compiler has trimmed from the sprite's top side\n\t\t\t\n\t\t\t[6] = normalised percentage of pixel data from the original sprite's width that has been saved to the texture page\n\t\t\t\n\t\t\t[7] = normalised percentage of pixel data from the original sprite's height that has been saved to the texture page",
					"Parameter": [
						{
							"_Name": "sprite",
							"_Type": "Asset.GMSprite",
							"_Optional": "false",
							"__text": "The index of the sprite to use."
						},
						{
							"_Name": "subimage",
							"_Type": "Real",
							"_Optional": "false",
							"__text": "The sub-image of the sprite to use."
						}
					],
					"_Name": "sprite_get_uvs",
					"_Deprecated": "false",
					"_ReturnType": "Array[Real]",
					"_Pure": "true"
				},
