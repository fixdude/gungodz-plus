					"_Deprecated": "true",
					"_ReturnType": "Undefined",
					"_Pure": "false"
				},
				{
					"Description": "With this function you can show, or suppress, the various different \"toast\" pop-up notifications relating to challenges. When the arguments are set to true these messages will appear, informing the player of any local or remote challenges received as well as those challenges that have been completed, while setting them to false will suppress these notifications.",
					"Parameter": [
						{
							"_Name": "receive",
							"_Type": "Bool",
							"_Optional": "false",
							"__text": "Show challenges received pop-up (true) or not (false)."
